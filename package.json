{
  "name": "@harborclient/plugin-load-tester",
  "type": "module",
  "scripts": {
    "release": "bash scripts/publish.sh",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r ../harborclient-plugin-load-tester.hcp manifest.json README.md dist",
    "sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.1.30",
    "chart.js": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
