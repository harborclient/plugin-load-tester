{
  "id": "com.harborclient.plugins.load-tester",
  "name": "Load Tester",
  "author": "HarborClient",
  "version": "1.0.3",
  "summary": "Fire repeated requests against an endpoint or collection and chart latency percentiles, throughput, and error rate.",
  "description": "README.md",
  "categories": ["testing", "collections", "requests"],
  "screenshots": [
     "https://raw.githubusercontent.com/harborclient/plugin-load-tester/main/screenshot.png"
  ],
  "engines": { "harborclient": ">=1.8.4" },
  "renderer": "dist/renderer.js",
  "permissions": ["ui", "storage", "database", "filesystem:pick"],
  "contributes": {
    "requestTabs": [{ "id": "load-tester", "title": "Load Tester" }],
    "responseTabs": [{ "id": "load-testing", "title": "Load Testing" }],
    "statusBarItems": [{ "id": "modal-host", "title": "Load Test Modal Host" }],
    "commands": [{ "id": "load-test.collection", "title": "Load Test Collection" }],
    "contextMenus": [
      {
        "id": "load-tester",
        "title": "Load Tester",
        "command": "load-test.collection",
        "when": ["collection", "folder"]
      }
    ]
  }
}
